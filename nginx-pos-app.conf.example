server {
    listen 80;
    server_name localhost;
    root "C:/Path/To/Your/Project/frontend-app/dist"; # Ganti dengan path hasil build frontend
    index index.html;

    # 1. FRONTEND: Handle React Routing (SPA)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 2. BACKEND: Proxy ke Laravel API
    # Asumsi: Laravel jalan via 'php artisan serve' di port 8000
    location /api {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 3. STORAGE: Agar gambar/foto bisa diakses
    # Laravel storage link harus sudah dibuat (php artisan storage:link)
    location /storage {
        alias "C:/Path/To/Your/Project/backend-app/public/storage"; # Ganti path ini ke folder storage public laravel
        try_files $uri $uri/ =404;
    }

    # Optimasi Static Files (JS/CSS)
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg)$ {
        expires max;
        log_not_found off;
    }
}
